{
  "expo": {
    "name": "SlyderChat",
    "slug": "slyderchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "slyderchat",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#faf9fe",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "package": "com.rohan.slyderchat",
      "adaptiveIcon": {
        "backgroundColor": "#006d2f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "userInterfaceStyle": "automatic",
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf9fe",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow SlyderChat to access your contacts to find friends already using the app."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SlyderChat to access your photos to send images and set your profile picture.",
          "cameraPermission": "Allow SlyderChat to access your camera to take photos to send."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df3b84a8-5ddf-497a-9a57-98003763ac3c"
      }
    }
  }
}
